{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "tests/**/*.ts"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "target": "esnext",
    "lib": ["esnext", "dom", "dom.iterable", "ESNext.Array"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"]
  }
}
